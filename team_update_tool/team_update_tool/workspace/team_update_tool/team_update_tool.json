 "content": "[{\"id\":\"header\",\"type\":\"header\",\"data\":{\"text\":\"<span class=\\\"h4\\\">Team Update Tool</span>\",\"col\":12}},{\"id\":\"desc\",\"type\":\"paragraph\",\"data\":{\"text\":\"Role-based task management workflow. Admins create and assign tasks to Team Leaders, who assign to Team Members. Team Members complete tasks and upload work. Viewers can view approved projects only.\\n\\nTo get started, create a Team first, then create Tasks and assign them through the workflow.\",\"col\":12}},{\"id\":\"shortcuts_section\",\"type\":\"spacer\",\"data\":{\"col\":12}},{\"id\":\"sc_new_task\",\"type\":\"shortcut\",\"data\":{\"shortcut_name\":\"New Task\",\"col\":3}},{\"id\":\"sc_all_tasks\",\"type\":\"shortcut\",\"data\":{\"shortcut_name\":\"All Tasks\",\"col\":3}},{\"id\":\"sc_teams\",\"type\":\"shortcut\",\"data\":{\"shortcut_name\":\"Teams\",\"col\":3}},{\"id\":\"sc_report\",\"type\":\"shortcut\",\"data\":{\"shortcut_name\":\"Project Status Summary\",\"col\":3}},{\"id\":\"sc_settings\",\"type\":\"shortcut\",\"data\":{\"shortcut_name\":\"Team Update Settings\",\"col\":3}},{\"id\":\"cards_section\",\"type\":\"spacer\",\"data\":{\"col\":12}}]",
